# ローカル開発用のひな形（このファイルを secrets.toml にコピーして使う）
# クラウド公開時は Streamlit Cloud の「Secrets」画面に同じ内容を貼る

[timetree]
personal_token = "ここにTimeTreeパーソナルアクセストークン"
calendar_id = "ここにカレンダーID"

[deploy]
platform = "cloud"

# --- スプレッドシート永続化（任意・推奨）---
# 設定手順: SHEETS_SETUP.md を参照
#
# [sheets]
# spreadsheet_id = "スプレッドシートID"
#
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "...@....iam.gserviceaccount.com"
# ...
